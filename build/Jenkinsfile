import groovy.transform.Field

@Field String TOPIC = PipelineVariables.techOpsKafkaTopic


pipeline {
    agent 'docker'

    environment {
        DOCKER_IMAGE = 's2.ubuntu.home:5000/alpine/python/3.13.2'
        DOCKER_TAG = "${env.BUILD_NUMBER}"
        DOCKER_REGISTRY = 's2.ubuntu.home:5000'  // e.g., index.docker.io or registry.example.com
//        DOCKER_CREDENTIALS_ID = 'docker-credentials' // Jenkins credentials ID
    }

    stages {
        stage('Build Image') {
            steps {
                script {
                    docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
//                    docker.withRegistry("https://${DOCKER_REGISTRY}", "${DOCKER_CREDENTIALS_ID}") {
                     docker.withRegistry("http://${DOCKER_REGISTRY}") {
                        docker.image("${DOCKER_IMAGE}:${DOCKER_TAG}").push()
                    }
                }
            }
        }
    }
    post {
        always {
            kafkaBuildReporter()
        }
        cleanup {
            deleteDir()
        }
    }
}